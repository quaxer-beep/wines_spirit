# App
APP_NAME=Wines & Spirits E-Commerce
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

USE_SQLITE=True

# PostgreSQL (not required when USE_SQLITE=True)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=wines_pos

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# M-Pesa
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_PASSKEY=your_passkey
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=https://your-domain.com/api/v1/payments/mpesa/callback

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# SMS
SMS_API_URL=https://api.example.com/sms/send
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=WINESPOS

# WhatsApp
WHATSAPP_API_URL=https://graph.facebook.com/v21.0
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=eu-west-1
S3_BUCKET_NAME=wines-spirits-verification-docs

# Sentry
SENTRY_DSN=

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Delivery Fees
BASE_DELIVERY_FEE=100
DELIVERY_PER_KM_RATE=30
FUEL_ADJUSTMENT_PCT=5

# Loyalty
LOYALTY_POINTS_PER_KES=1
LOYALTY_REDEMPTION_RATE=0.05
LOYALTY_MIN_REDEMPTION=100
LOYALTY_POINTS_EXPIRY_DAYS=365

# Legal
LEGAL_DRINKING_AGE=18

# Sync
SYNC_INTERVAL_SECONDS=300
POS_DATABASE_PATH=/data/pos_databases
